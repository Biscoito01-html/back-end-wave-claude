# ─────────────────────────────────────────────────────────────
# BACKEND (NestJS) — Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────
PORT=3002
BACKEND_URL="http://localhost:3002"
FRONTEND_URL="http://localhost:8080"

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5433/wavepage_db?schema=openclaude_mvp"

# ── Autenticação JWT ─────────────────────────────────────────
JWT_SECRET="sua_chave_jwt_secreta_aqui"
JWT_EXPIRES_IN="7d"

# ── Criptografia de chaves API ────────────────────────────────
ENCRYPTION_SECRET="exatamente_32_caracteres_aqui_ok"

# ── Chave OpenRouter global (fallback) ───────────────────────
OPENAI_API_KEY=""

# ── Serviço OpenClaude (Bun HTTP) ─────────────────────────────
# ATENÇÃO: o servidor Bun (scripts/start-http-stream.ts) lê HTTP_PORT.
# O NestJS lê OPENCLAUDE_HTTP_PORT para saber onde conectar.
# Mantenha os dois com o mesmo valor se mudar a porta padrão (50052).
OPENCLAUDE_HTTP_HOST="127.0.0.1"
OPENCLAUDE_HTTP_PORT="50052"
# HTTP_PORT=50052  # defina também no ambiente do servidor Bun se mudar acima
OPENCLAUDE_WORKDIR="../../"

# ── Uploads (opcional) ───────────────────────────────────────
# UPLOAD_DIR="/caminho/absoluto/para/uploads"
