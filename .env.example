# ─────────────────────────────────────────────────────────────
# BACKEND (NestJS) — Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────
PORT=3002
BACKEND_URL="http://localhost:3002"
# FRONTEND_URL não é mais necessário: este serviço roda como
# microserviço atrás do gateway e não configura CORS próprio.
# FRONTEND_URL="http://localhost:8080"

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5433/wavepage_db?schema=openclaude_mvp"

# ── Autenticação JWT ─────────────────────────────────────────
# OBRIGATÓRIO em produção. Deve ter pelo menos 16 caracteres (por
# compat com o secret compartilhado do gateway). Ideal 32+; planeje
# rotação coordenada com a frota de microserviços ao longo do tempo.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# IMPORTANTE: este valor DEVE ser idêntico ao do gateway (api-control-panel-core).
JWT_SECRET="sua_chave_jwt_secreta_aqui"
JWT_EXPIRES_IN="7d"

# Quando "true", habilita /auth/register e /auth/login locais. Em
# produção deve ficar "false" (usar o gateway para emissão do JWT).
ENABLE_LOCAL_AUTH=false

# ── Criptografia de chaves API ────────────────────────────────
# OBRIGATÓRIO em produção. DEVE ter EXATAMENTE 32 caracteres. NÃO use
# o valor default. Gere um secret real, ex:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64').slice(0,32))"
# Rotação: trocar esse valor invalida todas as chaves criptografadas
# (ApiKey.encryptedKey, UserIntegration.encryptedToken). Documentado em
# DEPLOYMENT.md seção "Rotação de secrets".
ENCRYPTION_SECRET="exatamente_32_caracteres_aqui_ok"

# ── Chave OpenRouter global (fallback) ───────────────────────
OPENAI_API_KEY=""

# ── Serviço OpenClaude (Bun HTTP) ─────────────────────────────
# ATENÇÃO: o servidor Bun (scripts/start-http-stream.ts) lê HTTP_PORT.
# O NestJS lê OPENCLAUDE_HTTP_PORT para saber onde conectar.
# Mantenha os dois com o mesmo valor se mudar a porta padrão (50052).
# Em produção, OPENCLAUDE_HTTP_HOST DEVE ser 127.0.0.1 (o Bun NÃO pode
# ser exposto na rede; apenas o NestJS conversa com ele localmente).
OPENCLAUDE_HTTP_HOST="127.0.0.1"
OPENCLAUDE_HTTP_PORT="50052"
# HTTP_PORT=50052  # defina também no ambiente do servidor Bun se mudar acima

# ── Workspaces por usuário ───────────────────────────────────
# Pasta-pai onde serão criadas as subpastas <userId>/ isoladas para cada
# funcionário. Em dev pode deixar o default (./workspaces). Em produção,
# aponte para um volume persistente (ex: /var/openclaude/workspaces).
# Pode ser sobrescrito em runtime pelo painel admin (GlobalSettings.workingDirectory).
WORKSPACES_ROOT="./workspaces"

# ── Registro público ─────────────────────────────────────────
# Quando "true", POST /auth/register retorna 403 e somente admins podem
# criar novos usuários pelo painel. Recomendado em produção para evitar
# que qualquer um com acesso à URL crie conta.
DISABLE_PUBLIC_REGISTER=false

# ── Uploads (opcional) ───────────────────────────────────────
# UPLOAD_DIR="/caminho/absoluto/para/uploads"

# ─────────────────────────────────────────────────────────────
# Produção (checklist rápido — detalhes em DEPLOYMENT.md)
# ─────────────────────────────────────────────────────────────
# NODE_ENV=production
# JWT_SECRET="<idêntico ao do gateway api-control-panel-core>"    # >=16 chars
# ENCRYPTION_SECRET="<32 chars exatos, não default>"
# WORKSPACES_ROOT="/var/openclaude/workspaces"       # caminho absoluto, volume persistente
# OPENCLAUDE_HTTP_HOST="127.0.0.1"                   # bloqueio na validação de boot
# DISABLE_PUBLIC_REGISTER=true
# ENABLE_LOCAL_AUTH=false                            # auth centralizada no gateway
